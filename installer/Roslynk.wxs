<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX 5 source for the Roslynk MSI. It installs the published, self-contained service into
  Program Files and registers + starts the "Roslynk" Windows service.

  Build (requires the WiX toolset — `dotnet tool install --global wix`, and a prior `publish.ps1`):
      dotnet build installer/Morris.Roslynk.Installer.wixproj -c Release

  The UpgradeCode below is the stable product identity across versions; do NOT change it once released.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
	<Package
		Name="Roslynk"
		Manufacturer="Air Software Ltd"
		Version="1.0.0.0"
		UpgradeCode="7B2A1C9E-4D3F-4A8B-9C1D-0E5F6A7B8C9D"
		Scope="perMachine">

		<MajorUpgrade DowngradeErrorMessage="A newer version of Roslynk is already installed." />
		<MediaTemplate EmbedCab="yes" />

		<StandardDirectory Id="ProgramFiles64Folder">
			<Directory Id="INSTALLFOLDER" Name="Roslynk" />
		</StandardDirectory>

		<Feature Id="Main" Title="Roslynk service">
			<ComponentGroupRef Id="RoslynkPublishedFiles" />
			<ComponentRef Id="RoslynkService" />
		</Feature>
	</Package>

	<Fragment>
		<!-- Everything from the publish output except the service host exe (installed in its own component). -->
		<ComponentGroup Id="RoslynkPublishedFiles" Directory="INSTALLFOLDER">
			<Files Include="$(PublishDir)\**">
				<Exclude Files="$(PublishDir)\Morris.Roslynk.Mcp.exe" />
			</Files>
		</ComponentGroup>

		<!-- The service host exe, registered and started as the loopback-only "Roslynk" Windows service. -->
		<Component Id="RoslynkService" Directory="INSTALLFOLDER" Bitness="always64">
			<File Id="RoslynkExe" Source="$(PublishDir)\Morris.Roslynk.Mcp.exe" KeyPath="yes" />
			<ServiceInstall
				Id="RoslynkServiceInstall"
				Name="Roslynk"
				DisplayName="Roslynk — C# semantic intelligence"
				Description="Roslyn-based C# semantic intelligence MCP server. Listens on loopback only."
				Type="ownProcess"
				Start="auto"
				ErrorControl="normal"
				Account="LocalSystem" />
			<ServiceControl
				Id="RoslynkServiceControl"
				Name="Roslynk"
				Start="install"
				Stop="both"
				Remove="uninstall"
				Wait="yes" />
		</Component>
	</Fragment>
</Wix>
